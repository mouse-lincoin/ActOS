{
  "name": "actos",
  "version": "0.0.0",
  "private": true,
  "description": "ActOS Runtime v0 — local supervised Web Agent Runtime",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "demo": "pnpm --filter @actos/mock-admin build && pnpm --filter @actos/mock-admin demo",
    "lint": "pnpm -r lint",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.1"
  }
}
