{
  "name": "@actos/runtime-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Local Fastify runtime server for ActOS v0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "pretest": "pnpm --filter @actos/browser-playwright exec playwright install chromium",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@actos/browser-playwright": "workspace:*",
    "@actos/core": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "fastify": "^5.4.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "vitest": "^3.2.1"
  }
}
