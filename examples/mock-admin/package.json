{
  "name": "@actos/mock-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Deterministic mock admin site for ActOS Runtime v0 demos",
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite",
    "start": "node dist/src/server.js",
    "demo": "node dist/scripts/run-demo.js",
    "pretest": "vite build && pnpm --filter @actos/browser-playwright exec playwright install chromium",
    "test": "vitest run",
    "lint": "eslint src scripts tests"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@actos/browser-playwright": "workspace:*",
    "@actos/core": "workspace:*",
    "@actos/runtime-server": "workspace:*",
    "@actos/sdk": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "jsdom": "^26.1.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  }
}
